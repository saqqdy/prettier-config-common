{
	"$schema": "http://json.schemastore.org/prettierrc",
	"printWidth": 100,
	"tabWidth": 4,
	"useTabs": true,
	"semi": false,
	"singleQuote": true,
	"quoteProps": "as-needed",
	"jsxSingleQuote": false,
	"trailingComma": "es5",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"arrowParens": "avoid",
	"rangeStart": 0,
	"rangeEnd": null,
	"parser": "",
	"plugins": [],
	"pluginSearchDirs": [],
	"filepath": "",
	"requirePragma": false,
	"insertPragma": false,
	"proseWrap": "preserve",
	"htmlWhitespaceSensitivity": "css",
	"endOfLine": "auto",
	"cursorOffset": -1,
	"overrides": [
		{
			"files": ["*.json5"],
			"options": {
				"singleQuote": false,
				"quoteProps": "preserve"
			}
		},
		{
			"files": ["*.yml", "*.yaml", "*.toml", "*.md"],
			"options": {
				"useTabs": false,
				"singleQuote": false,
				"tabWidth": 2
			}
		},
		{
			"files": ["*.md"],
			"options": {
				"useTabs": false,
				"singleQuote": true,
				"tabWidth": 2
			}
		},
		{
			"files": ".prettierrc",
			"options": {
				"parser": "json"
			}
		}
	]
}
